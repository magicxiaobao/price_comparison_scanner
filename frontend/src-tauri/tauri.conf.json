{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "price-comparison-scanner",
  "version": "0.1.0",
  "identifier": "com.a1234.price-comparison-scanner",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "三方比价支出依据扫描工具",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:17396 http://127.0.0.1:17397 http://127.0.0.1:17398 http://127.0.0.1:17399 http://127.0.0.1:17400 http://127.0.0.1:17401 http://127.0.0.1:17402 http://127.0.0.1:17403 http://127.0.0.1:17404 http://127.0.0.1:17405 http://127.0.0.1:17406; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
